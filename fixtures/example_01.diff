+"""Miscellaneous helper functions used across the project."""
+
+from datetime import datetime
+
+
+def format_timestamp(ts: float, fmt: str = "%Y-%m-%d %H:%M") -> str:
+    """Convert a Unix timestamp to a human-readable string.
+
+    Args:
+        ts: Unix timestamp in seconds.
+        fmt: Desired output format (strftime-compatible).
+    """
+    return datetime.utcfromtimestamp(ts).strftime(fmt)
+
+
+def slugify(text: str) -> str:
+    """Create a URL-friendly slug from arbitrary text."""
+    return text.lower().strip().replace(" ", "-")
